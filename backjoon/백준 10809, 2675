#include <stdio.h>
#include <string.h>


int main() {

	int cnt[26] = { 0 , };

	char s[101];

	scanf("%s", s);

	for (int i = 0; i < strlen(s); i++) {
		if (cnt[s[i] - 'a'] == 0) cnt[s[i] - 'a'] = i + 1;
	}

	for (int i = 0; i < 26; i++) {
		if (cnt[i] == 0) printf("-1 ");
		else printf("%d ", cnt[i] - 1);
	}

	return 0;
}

#include <stdio.h>
#include <string.h>


int main() {

	int t, R;
	char s[21];

	scanf("%d", &t);

	while (t--) {
		scanf("%d", &R);
		scanf("%s", s);

		for (int i = 0; i < strlen(s); i++) {
			for (int k = 0; k < R; k++) {
				printf("%c", s[i]);
			}
		}
		printf("\n");
	}


	return 0;
}
